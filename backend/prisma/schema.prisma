generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./ifakeshop.db"
}

model Product {
  id              String   @id @default(cuid())
  name            String
  description     String
  category        String
  subcategory     String
  brand           String
  price           Float
  msrp            Float
  currency        String   @default("USD")
  imageIndex      Int      @default(0)
  specifications  String   @default("{}")
  colors          String   @default("[]")
  sizes           String   @default("[]")
  rating          Float    @default(0)
  reviewCount     Int      @default(0)
  releaseYear     Int
  inStock         Boolean  @default(true)
  isLimitedEdition Boolean @default(false)
  isRare          Boolean  @default(false)
  isFantasy       Boolean  @default(false)
  isFutureTech    Boolean  @default(false)
  tags            String   @default("[]")
  features        String   @default("[]")
  popularity      Int      @default(0)
  createdAt       DateTime @default(now())

  reviews Review[]
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userName  String
  rating    Int
  title     String
  content   String
  date      DateTime @default(now())
  helpful   Int      @default(0)

  product Product @relation(fields: [productId], references: [id])
}

model Collection {
  id          String @id
  name        String
  description String
  image       String
  productIds  String @default("[]")
  type        String
}
